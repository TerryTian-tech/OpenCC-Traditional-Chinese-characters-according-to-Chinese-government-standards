{
  "name": "Traditional Chinese to Traditional Chinese (Chinese Government standard)",
  "normalization": [
    { "dict": { "type": "text", "file": "CJK_Compatibility_Ideographs.txt" } }
  ],
  "segmentation": {
    "type": "jieba",
    "resources": {
      "dict_path": "jieba_dict/jieba.dict.ancient.chinese.traditional.utf8",
      "model_path": "jieba_dict/hmm_model.utf8",
      "user_dict_path": "jieba_dict/user.dict.traditional.utf8"
    }
  },
  "conversion_chain": [
    {
      "dict": {
        "type": "group",
        "match_policy": "short_circuit",
        "dicts": [
          { "type": "text", "file": "TGPhrases.txt" },
          { "type": "text", "file": "TGCharacters.txt" }
        ]
      }
    }
  ]
}